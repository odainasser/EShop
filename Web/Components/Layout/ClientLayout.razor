@using Microsoft.AspNetCore.Components.Authorization
@using Web.Components.Common
@inject IAuthenticationService AuthService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject AuthenticationStateProvider AuthStateProvider
@inject IMediaService MediaService

<div class="min-h-screen bg-gray-50">
    <!-- Top Navigation Bar -->
    <PanelHeader HomeUrl="/client"
    IsSidebarOpen="@isSidebarOpen"
    OnMenuToggle="@ToggleSidebar"
    DisplayName="@displayName"
    AvatarUrl="@avatarUrl"
    UserEmail="@currentUser?.Email"
    DefaultInitial="C">
        <MenuItems>
            <a href="/client/account" class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-gray-100">
                <i class="bi bi-person-circle"></i>
                <span>@Localizer["MyProfile"]</span>
            </a>
            <a href="/client/activity" class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-gray-100">
                <i class="bi bi-journal-text"></i>
                <span>@Localizer["MyActivity"]</span>
            </a>
        </MenuItems>
    </PanelHeader>

    <!-- Mobile Sidebar Overlay -->
    @if (isSidebarOpen)
    {
        <div @onclick="CloseSidebar" class="fixed inset-0 bg-black bg-opacity-50 z-40 lg:hidden"></div>
    }

    <!-- Left Sidebar - Fixed on desktop -->
    <aside class="@GetSidebarClasses()">
        <nav class="p-4 space-y-1">
            <!-- Dashboard -->
            <NavLink href="/client" 
                     @onclick="CloseSidebar"
                     class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-gray-700 hover:bg-bf-primary hover:text-bf-primary-contrast transition-all duration-200 font-medium"
                     ActiveClass="bg-bf-primary text-bf-primary-contrast shadow-sm"
                     Match="NavLinkMatch.All">
                <i class="bi bi-speedometer2 text-lg"></i>
                <span>@Localizer["Dashboard"]</span>
            </NavLink>

            <!-- Account Section -->
            <div class="pt-4 pb-2">
                <p class="px-4 text-xs font-semibold text-gray-400 uppercase tracking-wider">@Localizer["YourAccount"]</p>
            </div>

            <NavLink href="/client/account" 
                     @onclick="CloseSidebar"
                     class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-gray-700 hover:bg-bf-primary hover:text-bf-primary-contrast transition-all duration-200 font-medium"
                     ActiveClass="bg-bf-primary text-bf-primary-contrast shadow-sm">
                <i class="bi bi-person text-lg"></i>
                <span>@Localizer["MyProfile"]</span>
            </NavLink>

            <NavLink href="/client/activity" 
                     @onclick="CloseSidebar"
                     class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-gray-700 hover:bg-bf-primary hover:text-bf-primary-contrast transition-all duration-200 font-medium"
                     ActiveClass="bg-bf-primary text-bf-primary-contrast shadow-sm">
                <i class="bi bi-journal-text text-lg"></i>
                <span>@Localizer["MyActivity"]</span>
            </NavLink>
        </nav>
    </aside>

    <!-- Main Content -->
    <main class="pt-16 lg:ms-64 min-h-screen flex flex-col">
        <div class="p-4 lg:p-6 flex-1">
            @Body
        </div>
        <PanelFooter />
    </main>
</div>

<div id="blazor-error-ui" class="fixed bottom-0 left-0 right-0 bg-red-600 text-white p-4 shadow-lg hidden" data-nosnippet>
    <div class="flex items-center justify-between max-w-7xl mx-auto">
        <div class="flex items-center gap-3">
            <i class="bi bi-exclamation-triangle-fill text-xl"></i>
            <span>@Localizer["ErrorOccurred"]</span>
            <a href="." class="underline hover:no-underline">@Localizer["Reload"]</a>
        </div>
        <button class="text-white hover:text-gray-200 text-2xl" onclick="document.getElementById('blazor-error-ui').style.display='none'">&times;</button>
    </div>
</div>

@code {
    [Parameter]
    public RenderFragment Body { get; set; }

    private UserDto? currentUser;
    private string? avatarUrl;
    private string displayName = string.Empty;
    private bool isSidebarOpen = false;

    private void ToggleSidebar()
    {
        isSidebarOpen = !isSidebarOpen;
    }

    private void CloseSidebar()
    {
        isSidebarOpen = false;
    }

    private string GetSidebarClasses()
    {
        var baseClasses = "fixed top-16 w-64 h-[calc(100vh-4rem)] bg-white shadow-sm border-e border-gray-200 overflow-y-auto transition-transform duration-300 ease-in-out z-40";
        
        if (isSidebarOpen)
        {
            return $"{baseClasses} left-0 rtl:left-auto rtl:right-0 translate-x-0";
        }
        else
        {
            return $"{baseClasses} left-0 rtl:left-auto rtl:right-0 -translate-x-full rtl:translate-x-full lg:translate-x-0 lg:rtl:translate-x-0";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var relative = Navigation.ToBaseRelativePath(Navigation.Uri);

        // If an authenticated user who is NOT a client attempts to access any /client/* route, redirect them
        if (user?.Identity?.IsAuthenticated == true && !user.IsInRole(Roles.Client))
        {
            if (!string.IsNullOrEmpty(relative) && relative.StartsWith("client", StringComparison.OrdinalIgnoreCase))
            {
                // Redirect admin/manager/support to admin panel
                Navigation.NavigateTo("/admin", forceLoad: true);
                return;
            }
        }

        // If authenticated client, block access to /admin/* areas
        if (user?.Identity?.IsAuthenticated == true && user.IsInRole(Roles.Client))
        {
            if (!string.IsNullOrEmpty(relative))
            {
                // Block access to /admin/* routes - redirect to /client
                if (relative.StartsWith("admin", StringComparison.OrdinalIgnoreCase))
                {
                    Navigation.NavigateTo("/client", forceLoad: true);
                    return;
                }
                
                // If not in client/* area and not landing page, redirect to client
                if (!relative.StartsWith("client", StringComparison.OrdinalIgnoreCase))
                {
                    // Allow access to public routes like login, register, etc.
                    var publicRoutes = new[] { "login", "register", "forgot-password", "reset-password", "logout" };
                    var isPublicRoute = publicRoutes.Any(r => relative.StartsWith(r, StringComparison.OrdinalIgnoreCase));
                    
                    if (!isPublicRoute)
                    {
                        Navigation.NavigateTo("/client", forceLoad: true);
                        return;
                    }
                }
            }
        }

        // Load current user for authorized state when authenticated
        if (user?.Identity?.IsAuthenticated == true)
        {
            var u = await AuthService.GetCurrentUserAsync();
            if (u != null)
            {
                currentUser = u;
                displayName = !string.IsNullOrEmpty(u.FirstName) 
                    ? $"{u.FirstName} {u.LastName}".Trim() 
                    : (!string.IsNullOrEmpty(u.DisplayName) ? u.DisplayName : u.Email ?? "Client");

                try
                {
                    var mediaList = await MediaService.GetMediaForEntityAsync(u.Id, "User", "avatar");
                    var avatar = mediaList.FirstOrDefault();
                    if (avatar != null)
                    {
                        avatarUrl = MediaService.GetMediaUrl(avatar);
                    }
                }
                catch { }
            }
        }
    }
}
