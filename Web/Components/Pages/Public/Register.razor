@page "/register"
@layout PublicLayout
@using Microsoft.AspNetCore.Components.Authorization
@using System.Text.RegularExpressions
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject IAuthenticationService AuthService
@inject AuthenticationStateProvider AuthStateProvider
@inject IJsonStringLocalizer Localizer

<PageTitle>@Localizer["Register"] - @Localizer["SharjahMuseumsAuthority"]</PageTitle>

<!-- Modern Museum Booking Registration -->
<div class="relative min-h-[calc(100vh-4rem)] bg-gradient-to-br from-purple-50 via-white to-purple-50 flex items-center justify-center p-4 overflow-hidden">
    
    <!-- Decorative Background Elements -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <div class="absolute top-0 left-0 w-96 h-96 bg-purple-200 rounded-full mix-blend-multiply filter blur-3xl opacity-20 animate-blob"></div>
        <div class="absolute top-0 right-0 w-96 h-96 bg-pink-200 rounded-full mix-blend-multiply filter blur-3xl opacity-20 animate-blob animation-delay-2000"></div>
        <div class="absolute bottom-0 left-1/2 w-96 h-96 bg-indigo-200 rounded-full mix-blend-multiply filter blur-3xl opacity-20 animate-blob animation-delay-4000"></div>
    </div>

    <!-- Main Container -->
    <div class="relative w-full max-w-6xl">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
            
            <!-- Left Side: Branding & Welcome -->
            <div class="hidden lg:block text-center lg:text-left space-y-6 px-8">
                
                
                <h1 class="text-5xl font-bold text-gray-900 leading-tight">
                    @Localizer["JoinUs"]
                    <span class="block text-transparent bg-clip-text bg-gradient-to-r from-purple-600 to-purple-900 mt-2">
                        @Localizer["SharjahMuseumsAuthority"]
                    </span>
                </h1>
            </div>

            <!-- Right Side: Registration Card -->
            <div class="w-full">
                <div class="relative bg-white/80 backdrop-blur-xl rounded-3xl shadow-2xl border border-white/20 p-8 sm:p-10">
                    
                    

                    <!-- Header -->
                    <div class="mb-8">
                        <h2 class="text-3xl font-bold text-gray-900 mb-2">@Localizer["CreateAccount"]</h2>
                        <p class="text-gray-600">@Localizer["FillDetailsToRegister"]</p>
                    </div>

                    <!-- Success Message -->
                    @if (registrationSuccess)
                    {
                        <div class="mb-6 p-4 bg-green-50 border border-green-200 rounded-xl flex items-start gap-3">
                            <i class="bi bi-check-circle-fill text-green-600 text-lg mt-0.5"></i>
                            <div>
                                <p class="text-green-800 font-medium">@Localizer["RegistrationSuccessful"]</p>
                                <p class="text-green-700 text-sm mt-1">@Localizer["RedirectingToPortal"]</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        <!-- Registration Form -->
                        <EditForm Model="@registerRequest" OnValidSubmit="@HandleRegister" FormName="registerForm">
                            <LocalizedDataAnnotationsValidator />

                            @if (!string.IsNullOrEmpty(errorMessage))
                            {
                                <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-xl flex items-start gap-3 animate-shake">
                                    <i class="bi bi-exclamation-triangle-fill text-red-600 text-lg mt-0.5"></i>
                                    <span class="text-red-800 text-sm">@SanitizeError(errorMessage)</span>
                                </div>
                            }

                            <div class="space-y-5">
                                <!-- Name Row -->
                                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                    <!-- First Name -->
                                    <div>
                                        <label for="firstName" class="block text-sm font-semibold text-gray-700 mb-2">
                                            @Localizer["FirstName"]
                                        </label>
                                        <div class="relative">
                                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                                <i class="bi bi-person text-gray-400"></i>
                                            </div>
                                            <InputText @bind-Value="registerRequest.FirstName" 
                                                       class="w-full pl-10 pr-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-all duration-200" 
                                                       id="firstName" 
                                                       placeholder="@Localizer["FirstName"]"
                                                       disabled="@isLoading" />
                                        </div>
                                        <ValidationMessage For="@(() => registerRequest.FirstName)" class="text-red-600 text-sm mt-1" />
                                    </div>

                                    <!-- Last Name -->
                                    <div>
                                        <label for="lastName" class="block text-sm font-semibold text-gray-700 mb-2">
                                            @Localizer["LastName"]
                                        </label>
                                        <div class="relative">
                                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                                <i class="bi bi-person text-gray-400"></i>
                                            </div>
                                            <InputText @bind-Value="registerRequest.LastName" 
                                                       class="w-full pl-10 pr-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-all duration-200" 
                                                       id="lastName" 
                                                       placeholder="@Localizer["LastName"]"
                                                       disabled="@isLoading" />
                                        </div>
                                        <ValidationMessage For="@(() => registerRequest.LastName)" class="text-red-600 text-sm mt-1" />
                                    </div>
                                </div>

                                <!-- Email Input -->
                                <div>
                                    <label for="email" class="block text-sm font-semibold text-gray-700 mb-2">
                                        @Localizer["EmailAddress"]
                                    </label>
                                    <div class="relative">
                                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                            <i class="bi bi-envelope text-gray-400"></i>
                                        </div>
                                        <InputText @bind-Value="registerRequest.Email" 
                                                   type="email"
                                                   class="w-full pl-10 pr-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-all duration-200" 
                                                   id="email" 
                                                   placeholder="@Localizer["EmailAddress"]"
                                                   disabled="@isLoading" />
                                    </div>
                                    <ValidationMessage For="@(() => registerRequest.Email)" class="text-red-600 text-sm mt-1" />
                                </div>

                                <!-- Password Input -->
                                <div>
                                    <label for="password" class="block text-sm font-semibold text-gray-700 mb-2">
                                        @Localizer["Password"]
                                    </label>
                                    <div class="relative">
                                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                            <i class="bi bi-lock text-gray-400"></i>
                                        </div>
                                        <InputText @bind-Value="registerRequest.Password" 
                                                   type="@(showPassword ? "text" : "password")"
                                                   class="w-full pl-10 pr-12 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-all duration-200" 
                                                   id="password" 
                                                   placeholder="@Localizer["EnterPassword"]"
                                                   disabled="@isLoading" />
                                        <button type="button" 
                                                class="absolute inset-y-0 right-0 pr-3 flex items-center text-gray-400 hover:text-gray-600 transition-colors"
                                                @onclick="TogglePasswordVisibility"
                                                tabindex="-1">
                                            <i class="bi @(showPassword ? "bi-eye-slash" : "bi-eye")"></i>
                                        </button>
                                    </div>
                                    <ValidationMessage For="@(() => registerRequest.Password)" class="text-red-600 text-sm mt-1" />
                                </div>

                                <!-- Confirm Password Input -->
                                <div>
                                    <label for="confirmPassword" class="block text-sm font-semibold text-gray-700 mb-2">
                                        @Localizer["ConfirmPassword"]
                                    </label>
                                    <div class="relative">
                                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                            <i class="bi bi-lock-fill text-gray-400"></i>
                                        </div>
                                        <InputText @bind-Value="registerRequest.ConfirmPassword" 
                                                   type="@(showConfirmPassword ? "text" : "password")"
                                                   class="w-full pl-10 pr-12 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-all duration-200" 
                                                   id="confirmPassword" 
                                                   placeholder="@Localizer["ConfirmPassword"]"
                                                   disabled="@isLoading" />
                                        <button type="button" 
                                                class="absolute inset-y-0 right-0 pr-3 flex items-center text-gray-400 hover:text-gray-600 transition-colors"
                                                @onclick="ToggleConfirmPasswordVisibility"
                                                tabindex="-1">
                                            <i class="bi @(showConfirmPassword ? "bi-eye-slash" : "bi-eye")"></i>
                                        </button>
                                    </div>
                                    <ValidationMessage For="@(() => registerRequest.ConfirmPassword)" class="text-red-600 text-sm mt-1" />
                                </div>

                                <!-- Register Button -->
                                <button type="submit" 
                                        disabled="@isLoading"
                                        class="w-full px-6 py-4 bg-gradient-to-r from-purple-600 to-purple-800 text-white font-semibold rounded-xl hover:from-purple-700 hover:to-purple-900 focus:outline-none focus:ring-4 focus:ring-purple-300 transition-all duration-200 shadow-lg hover:shadow-xl disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center gap-3 transform hover:scale-[1.02] active:scale-[0.98]">
                                    @if (isLoading)
                                    {
                                        <svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                                        </svg>
                                        <span>@Localizer["Processing"]</span>
                                    }
                                    else
                                    {
                                        <i class="bi bi-person-plus"></i>
                                        <span>@Localizer["Register"]</span>
                                    }
                                </button>

                                <!-- Login Link -->
                                <div class="text-center">
                                    <p class="text-gray-600">
                                        @Localizer["AlreadyHaveAccount"]
                                        <a href="/login" class="font-semibold text-purple-600 hover:text-purple-800 transition-colors">
                                            @Localizer["SignIn"]
                                        </a>
                                    </p>
                                </div>
                            </div>
                        </EditForm>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    @@keyframes blob {
        0% { transform: translate(0px, 0px) scale(1); }
        33% { transform: translate(30px, -50px) scale(1.1); }
        66% { transform: translate(-20px, 20px) scale(0.9); }
        100% { transform: translate(0px, 0px) scale(1); }
    }
    
    .animate-blob {
        animation: blob 7s infinite;
    }
    
    .animation-delay-2000 {
        animation-delay: 2s;
    }
    
    .animation-delay-4000 {
        animation-delay: 4s;
    }

    @@keyframes shake {
        0%, 100% { transform: translateX(0); }
        10%, 30%, 50%, 70%, 90% { transform: translateX(-5px); }
        20%, 40%, 60%, 80% { transform: translateX(5px); }
    }
    
    .animate-shake {
        animation: shake 0.5s;
    }
</style>

@code {
    private RegisterRequest registerRequest = new();
    private string errorMessage = string.Empty;
    private bool isLoading = false;
    private bool registrationSuccess = false;
    private bool showPassword = false;
    private bool showConfirmPassword = false;

    protected override async Task OnInitializedAsync()
    {
        // Check if already logged in
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user?.Identity?.IsAuthenticated == true)
        {
            RedirectUser(user);
        }
    }

    private void RedirectUser(System.Security.Claims.ClaimsPrincipal user)
    {
        if (user.IsInRole(Roles.Client))
        {
            Navigation.NavigateTo("/client", forceLoad: true);
        }
        else
        {
            Navigation.NavigateTo("/admin", forceLoad: true);
        }
    }

    private void TogglePasswordVisibility()
    {
        showPassword = !showPassword;
    }

    private void ToggleConfirmPasswordVisibility()
    {
        showConfirmPassword = !showConfirmPassword;
    }

    private async Task HandleRegister()
    {
        try
        {
            isLoading = true;
            errorMessage = string.Empty;

            var response = await AuthService.RegisterAsync(registerRequest);

            if (response.Success)
            {
                registrationSuccess = true;
                ((CustomAuthenticationStateProvider)AuthStateProvider).NotifyAuthenticationStateChanged();
                
                // Wait a moment to show success message, then redirect
                await Task.Delay(1500);
                Navigation.NavigateTo("/client", forceLoad: true);
            }
            else
            {
                errorMessage = response.Message ?? Localizer["RegistrationFailed"];
            }
        }
        catch (HttpRequestException httpEx)
        {
            Console.WriteLine($"Registration HTTP exception: {httpEx.Message}");
            Console.WriteLine($"Status Code: {httpEx.StatusCode}");

            if (httpEx.StatusCode == System.Net.HttpStatusCode.BadRequest)
            {
                errorMessage = Localizer["InvalidEmailFormat"];
            }
            else
            {
                errorMessage = Localizer["RegistrationError"];
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Registration exception: {ex.Message}");
            Console.WriteLine($"Exception type: {ex.GetType().Name}");
            errorMessage = Localizer["RegistrationError"];
        }
        finally
        {
            isLoading = false;
        }
    }

    private string SanitizeError(string msg)
    {
        if (string.IsNullOrEmpty(msg)) return string.Empty;
        var sanitized = Regex.Replace(msg, "\\s*Reload\\s*�?", "", RegexOptions.IgnoreCase);
        sanitized = sanitized.Replace("�","").Trim();
        return sanitized;
    }
}
