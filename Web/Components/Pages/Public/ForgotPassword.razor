@page "/forgot-password"
@layout PublicLayout
@inject IAuthenticationService AuthService
@inject NavigationManager Navigation
@inject IJsonStringLocalizer Localizer

<PageTitle>@Localizer["ForgotPasswordTitle"]</PageTitle>

<div class="min-h-screen flex items-center justify-center px-4 py-12 overflow-hidden">
    <div class="w-full max-w-md">
        <div class="bg-white rounded-2xl shadow-xl p-8">
            <div class="flex justify-between items-start mb-8">
                <div>
                    <h2 class="text-3xl font-bold text-gray-900 mb-2">@Localizer["ForgotPasswordTitle"]</h2>
                    <p class="text-gray-600">@Localizer["EnterEmailResetLink"]</p>
                </div>
                <LanguageSelector Alignment="right" />
            </div>

            @if (emailSent)
            {
                <div class="p-6 bg-green-50 border border-green-200 rounded-lg">
                    <div class="flex items-start gap-4">
                        <i class="bi bi-check-circle-fill text-green-600 text-2xl"></i>
                        <div>
                            <h5 class="font-semibold text-green-900 mb-2">@Localizer["CheckYourEmail"]</h5>
                            <p class="text-green-800 mb-2">@Localizer["IfAnAccountExistsResetLinkSent"]</p>
                            <p class="text-green-800">@Localizer["PleaseCheckYourEmail"]</p>
                        </div>
                    </div>
                </div>
                <div class="mt-6">
                    <a href="/login" 
                       class="w-full inline-flex items-center justify-center gap-2 py-3 px-4 bg-gradient-to-r from-purple-600 to-purple-800 text-white rounded-lg hover:from-purple-700 hover:to-purple-900 transition-all duration-200 shadow-lg hover:shadow-xl font-medium">
                        <i class="bi bi-arrow-left"></i>
                        <span>@Localizer["BackToLogin"]</span>
                    </a>
                </div>
            }
            else
            {
                @if (request != null)
                {
                    <EditForm Model="@request" OnValidSubmit="@HandleSubmit">
                        <LocalizedDataAnnotationsValidator />

                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="mb-4 p-4 bg-red-50 border border-red-200 rounded-lg flex items-start gap-3">
                                <i class="bi bi-exclamation-triangle-fill text-red-600 text-lg mt-0.5"></i>
                                <span class="text-red-800">@errorMessage</span>
                            </div>
                        }

                        <div class="mb-6">
                            <label for="email" class="block text-sm font-medium text-gray-700 mb-2">@Localizer["EmailAddress"]</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                    <i class="bi bi-envelope text-gray-400"></i>
                                </div>
                                <InputText @bind-Value="request.Email" 
                                           class="w-full pl-10 pr-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-all duration-200" 
                                           id="email" 
                                           placeholder="@Localizer["EmailAddress"]" 
                                           autocomplete="email" />
                            </div>
                            <ValidationMessage For="@(() => request.Email)" class="text-red-600 text-sm mt-1" />
                        </div>

                        <button type="submit" 
                                class="w-full py-3 px-4 bg-gradient-to-r from-purple-600 to-purple-800 text-white rounded-lg hover:from-purple-700 hover:to-purple-900 transition-all duration-200 shadow-lg hover:shadow-xl font-medium disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center gap-2 mb-4"
                                disabled="@isLoading">
                            @if (isLoading)
                            {
                                <svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                                </svg>
                                <span>@Localizer["Sending"]</span>
                            }
                            else
                            {
                                <i class="bi bi-send"></i>
                                <span>@Localizer["SendResetLink"]</span>
                            }
                        </button>

                        <div class="text-center">
                            <a href="/login" class="inline-flex items-center gap-2 text-purple-600 hover:text-purple-800 transition-colors duration-200">
                                <i class="bi bi-arrow-left"></i>
                                <span>@Localizer["BackToLogin"]</span>
                            </a>
                        </div>
                    </EditForm>
                }
            }
        </div>
    </div>
</div>

@code {
    private ForgotPasswordRequest? request;
    private bool isLoading = false;
    private bool emailSent = false;
    private string errorMessage = string.Empty;

    protected override void OnInitialized()
    {
        request = new ForgotPasswordRequest();
    }

    private async Task HandleSubmit()
    {
        if (request == null) return;

        isLoading = true;
        errorMessage = string.Empty;

        try
        {
            var response = await AuthService.ForgotPasswordAsync(request);
            
            if (response.Success)
            {
                emailSent = true;
            }
            else
            {
                errorMessage = response.Message ?? Localizer["ErrorOccurred"];
            }
        }
        catch (Exception ex)
        {
            errorMessage = Localizer["ErrorOccurred"];
        }
        finally
        {
            isLoading = false;
        }
    }
}
