@page "/client"
@layout Web.Components.Layout.ClientLayout
@using Microsoft.AspNetCore.Authorization
@inject IAuthenticationService AuthService
@inject NavigationManager Navigation
@inject IJsonStringLocalizer Localizer
@attribute [Authorize(Roles = "Client")]

<PageTitle>@Localizer["Dashboard"] - @Localizer["SharjahMuseumsAuthority"]</PageTitle>

@if (isLoading)
{
    <div class="flex justify-center items-center h-64">
        <svg class="animate-spin h-12 w-12 text-bf-primary" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
    </div>
}
else
{
    <!-- Welcome Header -->
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-gray-900">@Localizer["Welcome"], @(user?.FirstName ?? "User")!</h1>
        <p class="text-gray-500 mt-1">@Localizer["ClientPortalDescription"]</p>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="bg-white rounded-lg border border-gray-200 p-4">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-bf-primary/10 rounded-lg flex items-center justify-center">
                    <i class="bi bi-calendar-check text-xl text-bf-primary"></i>
                </div>
                <div>
                    <p class="text-2xl font-bold text-gray-900">@upcomingBookings</p>
                    <p class="text-xs text-gray-500">@Localizer["UpcomingBookings"]</p>
                </div>
            </div>
        </div>
        
        <div class="bg-white rounded-lg border border-gray-200 p-4">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-green-50 rounded-lg flex items-center justify-center">
                    <i class="bi bi-check-circle text-xl text-green-600"></i>
                </div>
                <div>
                    <p class="text-2xl font-bold text-gray-900">@completedVisits</p>
                    <p class="text-xs text-gray-500">@Localizer["CompletedVisits"]</p>
                </div>
            </div>
        </div>
        
        <div class="bg-white rounded-lg border border-gray-200 p-4">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-purple-50 rounded-lg flex items-center justify-center">
                    <i class="bi bi-people text-xl text-purple-600"></i>
                </div>
                <div>
                    <p class="text-2xl font-bold text-gray-900">@totalVisitors</p>
                    <p class="text-xs text-gray-500">@Localizer["TotalVisitors"]</p>
                </div>
            </div>
        </div>
        
        <div class="bg-white rounded-lg border border-gray-200 p-4">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-amber-50 rounded-lg flex items-center justify-center">
                    <i class="bi bi-clock-history text-xl text-amber-600"></i>
                </div>
                <div>
                    <p class="text-2xl font-bold text-gray-900">@pendingRequests</p>
                    <p class="text-xs text-gray-500">@Localizer["PendingRequests"]</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Bookings -->
    <div class="bg-white rounded-lg border border-gray-200">
        <div class="px-4 py-3 border-b border-gray-200 flex items-center justify-between">
            <h2 class="font-semibold text-gray-900">@Localizer["MyBookings"]</h2>
            <a href="/client/bookings" class="text-sm text-bf-primary hover:underline">@Localizer["ViewAll"]</a>
        </div>

        @if (recentBookings.Any())
        {
            <div class="divide-y divide-gray-100">
                @foreach (var booking in recentBookings)
                {
                    <div class="px-4 py-3 hover:bg-gray-50 flex items-center justify-between">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded-lg @(booking.Type == "University" ? "bg-bf-primary/10 text-bf-primary" : "bg-emerald-100 text-emerald-600") flex items-center justify-center">
                                <i class="bi @(booking.Type == "University" ? "bi-mortarboard" : "bi-backpack")"></i>
                            </div>
                            <div>
                                <p class="font-medium text-gray-900 text-sm">@booking.BookingNumber</p>
                                <p class="text-xs text-gray-500">@booking.VisitorCount @Localizer["Visitors"] � @booking.VisitDate.ToString("dd MMM yyyy")</p>
                            </div>
                        </div>
                        <span class="px-2 py-1 rounded text-xs font-medium @GetStatusClass(booking.Status)">
                            @GetLocalizedStatus(booking.Status)
                        </span>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="p-8 text-center">
                <div class="w-12 h-12 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-3">
                    <i class="bi bi-calendar-x text-xl text-gray-400"></i>
                </div>
                <p class="text-gray-500 text-sm mb-3">@Localizer["NoBookingsYet"]</p>
                <a href="/client/booking/university" class="inline-flex items-center gap-2 px-4 py-2 bg-bf-primary text-bf-primary-contrast text-sm rounded-lg hover:opacity-90">
                    <i class="bi bi-plus-lg"></i>
                    @Localizer["CreateFirstBooking"]
                </a>
            </div>
        }
    </div>
}

@code {
    private UserDto? user;
    private bool isLoading = true;
    
    private int upcomingBookings = 2;
    private int completedVisits = 5;
    private int totalVisitors = 127;
    private int pendingRequests = 1;

    private List<BookingItem> recentBookings = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            user = await AuthService.GetCurrentUserAsync();
            
            recentBookings = new List<BookingItem>
            {
                new BookingItem 
                { 
                    BookingNumber = "SMA-2024-0123", 
                    Type = "University", 
                    VisitDate = DateTime.Now.AddDays(5), 
                    VisitorCount = 25, 
                    Status = "Confirmed" 
                },
                new BookingItem 
                { 
                    BookingNumber = "SMA-2024-0118", 
                    Type = "School", 
                    VisitDate = DateTime.Now.AddDays(12), 
                    VisitorCount = 45, 
                    Status = "Pending" 
                },
                new BookingItem 
                { 
                    BookingNumber = "SMA-2024-0098", 
                    Type = "University", 
                    VisitDate = DateTime.Now.AddDays(-3), 
                    VisitorCount = 18, 
                    Status = "Completed" 
                }
            };
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading data: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private string GetStatusClass(string status)
    {
        return status switch
        {
            "Confirmed" => "bg-green-100 text-green-700",
            "Pending" => "bg-amber-100 text-amber-700",
            "Completed" => "bg-bf-primary/10 text-bf-primary",
            "Cancelled" => "bg-red-100 text-red-700",
            _ => "bg-gray-100 text-gray-700"
        };
    }

    private string GetLocalizedStatus(string status)
    {
        return status switch
        {
            "Confirmed" => Localizer["Confirmed"],
            "Pending" => Localizer["Pending"],
            "Completed" => Localizer["Completed"],
            "Cancelled" => Localizer["Cancelled"],
            _ => status
        };
    }

    private class BookingItem
    {
        public string BookingNumber { get; set; } = "";
        public string Type { get; set; } = "";
        public DateTime VisitDate { get; set; }
        public int VisitorCount { get; set; }
        public string Status { get; set; } = "";
    }
}
