@page "/admin/clients"
@attribute [Authorize]
@attribute [RequirePermission(Permissions.ClientsRead)]
@using Microsoft.AspNetCore.Authorization
@using Web.Authorization
@using Web.Components.Common
@using System.Globalization
@inject IUserManagementService UserService
@inject NavigationManager Navigation
@inject IJsonStringLocalizer Localizer

<PageTitle>@Localizer["ClientsManagement"] - BitFlow</PageTitle>

<div class="min-h-screen bg-gray-50 py-4 sm:py-8 px-2 sm:px-4">
    <div class="max-w-7xl mx-auto">
        <div class="bg-white rounded-2xl shadow-lg p-4 sm:p-8">
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4 mb-8">
                <div>
                    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 flex items-center gap-3">
                        <i class="bi bi-person-badge text-bf-primary"></i>
                        @Localizer["ClientsManagement"]
                    </h1>
                    <p class="text-gray-600 mt-2 text-sm sm:text-base">@Localizer["ManageClientAccounts"]</p>
                </div>
            </div>

            <!-- Search Bar -->
            <div class="mb-6">
                <div class="flex gap-3">
                    <div class="relative flex-1">
                        <div class="absolute inset-y-0 start-0 flex items-center ps-3 pointer-events-none">
                            <i class="bi bi-search text-gray-400"></i>
                        </div>
                        <input type="text" 
                               @bind="searchTerm" 
                               @bind:event="oninput"
                               @onkeypress="HandleSearchKeyPress"
                               class="w-full ps-10 pe-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-bf-primary/50 focus:border-bf-primary transition-all duration-200" 
                               placeholder="@Localizer["Search"]..." />
                    </div>
                    <button @onclick="SearchClients" 
                            class="inline-flex items-center gap-2 py-3 px-6 bg-bf-primary text-bf-primary-contrast rounded-lg hover:opacity-90 transition-all duration-200 shadow-lg hover:shadow-xl font-medium">
                        <i class="bi bi-search"></i>
                        <span class="hidden sm:inline">@Localizer["Search"]</span>
                    </button>
                </div>
            </div>

            @if (isLoading)
            {
                <div class="flex justify-center items-center py-12">
                    <svg class="animate-spin h-10 w-10 text-bf-primary" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                </div>
            }
            else if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="p-4 bg-red-50 border border-red-200 rounded-lg flex items-start gap-3">
                    <i class="bi bi-exclamation-triangle-fill text-red-600 text-lg mt-0.5"></i>
                    <span class="text-red-800">@errorMessage</span>
                </div>
            }
            else if (clients == null || !clients.Any())
            {
                <div class="text-center py-12">
                    <i class="bi bi-inbox text-6xl text-gray-300 mb-4"></i>
                    <p class="text-gray-500 text-lg">@Localizer["NoClientsFound"]</p>
                </div>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Client"]</th>
                                <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Email"]</th>
                                <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["PhoneNumber"]</th>
                                <th class="px-6 py-3 text-start text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Status"]</th>
                                <th class="px-6 py-3 text-end text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Actions"]</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            @foreach (var client in filteredClients)
                            {
                                <tr class="hover:bg-gray-50 transition-colors duration-150">
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <div class="flex items-center">
                                            @if (!string.IsNullOrEmpty(client.AvatarUrl))
                                            {
                                                <img src="@client.AvatarUrl" alt="@client.FullName" class="flex-shrink-0 h-10 w-10 rounded-full object-cover border border-gray-200" />
                                            }
                                            else
                                            {
                                                <div class="flex-shrink-0 h-10 w-10 bg-bf-primary/10 rounded-full flex items-center justify-center">
                                                    <i class="bi bi-person-fill text-bf-primary"></i>
                                                </div>
                                            }
                                            <div class="ms-4">
                                                <div class="text-sm font-medium text-gray-900">
                                                    <span class="text-sm text-gray-900">@client.FullName</span>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <div class="text-sm text-gray-900">@client.Email</div>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <div class="text-sm text-gray-900">@(client.PhoneNumber ?? "-")</div>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        @if (client.IsActive)
                                        {
                                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                                <i class="bi bi-check-circle-fill me-1"></i> @Localizer["Active"]
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                                                <i class="bi bi-x-circle-fill me-1"></i> @Localizer["Inactive"]
                                            </span>
                                        }
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-end text-sm font-medium">
                                        <div class="flex items-center justify-end gap-1">
                                            <AuthorizeView Policy="Permission:system.audit">
                                                <Authorized>
                                                    <button @onclick="() => ViewLogs(client.Id)"
                                                            class="p-2 text-amber-600 hover:text-amber-700 hover:bg-amber-50 rounded-lg transition-all duration-200"
                                                            title="@Localizer["ViewLogs"]">
                                                        <i class="bi bi-journal-text"></i>
                                                    </button>
                                                    <button @onclick="() => ViewUserActivities(client.Id)"
                                                            class="p-2 text-violet-600 hover:text-violet-700 hover:bg-violet-50 rounded-lg transition-all duration-200"
                                                            title="@Localizer["ViewUserActivities"]">
                                                        <i class="bi bi-activity"></i>
                                                    </button>
                                                </Authorized>
                                            </AuthorizeView>
                                            <AuthorizeView Policy="Permission:clients.write">
                                                <Authorized>
                                                    @if (client.IsSystemUser)
                                                    {
                                                        <button @onclick="() => ViewClient(client.Id)" 
                                                                class="p-2 text-teal-600 hover:text-teal-700 hover:bg-teal-50 rounded-lg transition-all duration-200" 
                                                                title="@Localizer["ViewDetails"]">
                                                            <i class="bi bi-eye"></i>
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <button @onclick="() => EditClient(client.Id)"
                                                                class="p-2 text-sky-600 hover:text-sky-700 hover:bg-sky-50 rounded-lg transition-all duration-200"
                                                                title="@Localizer["Edit"]">
                                                            <i class="bi bi-pencil-square"></i>
                                                        </button>
                                                    }
                                                </Authorized>
                                                <NotAuthorized>
                                                    <button @onclick="() => ViewClient(client.Id)" 
                                                            class="p-2 text-teal-600 hover:text-teal-700 hover:bg-teal-50 rounded-lg transition-all duration-200" 
                                                            title="@Localizer["ViewDetails"]">
                                                        <i class="bi bi-eye"></i>
                                                    </button>
                                                </NotAuthorized>
                                            </AuthorizeView>
                                            <AuthorizeView Policy="Permission:clients.delete">
                                                <Authorized>
                                                    @if (!client.IsSystemUser)
                                                    {
                                                        <button @onclick="() => DeleteClientAsync(client.Id)" 
                                                                class="p-2 text-rose-600 hover:text-rose-700 hover:bg-rose-50 rounded-lg transition-all duration-200" 
                                                                title="@Localizer["Delete"]">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <button disabled 
                                                                class="p-2 text-gray-300 cursor-not-allowed" 
                                                                title="@Localizer["SystemAdminModifyWarning"]">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    }
                                                </Authorized>
                                                <NotAuthorized>
                                                    <button disabled class="p-2 text-gray-300 cursor-not-allowed">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </NotAuthorized>
                                            </AuthorizeView>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <Pagination PageIndex="@pageIndex" 
                                TotalPages="@totalPages" 
                                TotalCount="@totalCount" 
                                PageSize="@pageSize" 
                                OnPageChanged="@OnPageChanged" />
                </div>
            }
        </div>
    </div>
</div>


<ConfirmModal IsVisible="@showDeleteConfirm"
Title="@Localizer["ConfirmDeleteUserTitle"]"
Message="@Localizer["ConfirmDeleteUserMessage"]"
OnConfirm="@DeleteClient"
OnCancel="@CancelDelete"
IsDanger="true" />

@code {
    private List<UserResponse> clients = new();
    private bool isLoading = true;
    private string errorMessage = string.Empty;
    private string searchTerm = string.Empty;
    private bool isAr = false;
    
    private bool showDeleteConfirm = false;
    private Guid clientToDelete;

    // Pagination
    private int pageIndex = 1;
    private int pageSize = 10;
    private int totalPages = 1;
    private int totalCount = 0;

    private IEnumerable<UserResponse> filteredClients => string.IsNullOrWhiteSpace(searchTerm) 
        ? clients 
        : clients.Where(c => 
            (c.FullName?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (c.Email?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (c.PhoneNumber?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false));

    protected override async Task OnInitializedAsync()
    {
        isAr = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName.Equals("ar", StringComparison.OrdinalIgnoreCase);
        await LoadClients();
    }

    private async Task LoadClients()
    {
        isLoading = true;
        errorMessage = string.Empty;
        
        try
        {
            // Get only users with Client role
            var result = await UserService.GetAllUsersAsync(pageIndex, pageSize, role: "Client");
                clients = result.Items;
                totalPages = result.TotalPages;
                totalCount = result.TotalCount;
            }
        catch (Exception ex)
        {
            errorMessage = Localizer["FailedToLoadClients"] + $": {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
    
    private async Task OnPageChanged(int newPageIndex)
    {
        pageIndex = newPageIndex;
        await LoadClients();
    }

    private void SearchClients()
    {
        // Trigger re-render with filtered results
        StateHasChanged();
    }

    private void HandleSearchKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            SearchClients();
        }
    }

    private void EditClient(Guid clientId)
    {
        Navigation.NavigateTo($"/admin/clients/edit/{clientId}");
    }

    private void ViewClient(Guid clientId)
    {
        Navigation.NavigateTo($"/admin/clients/edit/{clientId}");
    }

    private void ViewLogs(Guid clientId)
    {
        var uri = $"/admin/logs?entityName=User&entityId={clientId}";
        Navigation.NavigateTo(uri, forceLoad: false);
    }

    private void ViewUserActivities(Guid clientId)
    {
        var uri = $"/admin/logs?userId={clientId}";
        Navigation.NavigateTo(uri, forceLoad: false);
    }

    private void DeleteClientAsync(Guid clientId)
    {
        clientToDelete = clientId;
        showDeleteConfirm = true;
    }

    private async Task DeleteClient()
    {
        try
        {
            await UserService.DeleteUserAsync(clientToDelete);
            await LoadClients();
            showDeleteConfirm = false;
        }
        catch (Exception ex)
        {
            errorMessage = Localizer["FailedToDeleteUser"] + $": {ex.Message}";
            showDeleteConfirm = false;
        }
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
        clientToDelete = Guid.Empty;
    }
    }
