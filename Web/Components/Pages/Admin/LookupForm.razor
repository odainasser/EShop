@page "/admin/lookups/create"
@page "/admin/lookups/edit/{LookupId:guid}"
@attribute [Authorize]
@attribute [RequirePermission(Permissions.LookupsWrite)]
@using Microsoft.AspNetCore.Authorization
@using System.ComponentModel.DataAnnotations
@using Web.Constants
@inject ILookupService LookupService
@inject NavigationManager Navigation
@inject IJsonStringLocalizer Localizer

<PageTitle>@(IsEditMode ? Localizer["EditLookup"] : Localizer["CreateLookup"]) - BitFlow</PageTitle>

<div class="min-h-screen bg-gray-50 py-4 sm:py-8 px-2 sm:px-4">
    <div class="max-w-4xl mx-auto">
        <div class="bg-white rounded-2xl shadow-lg p-4 sm:p-8">
            <div class="mb-8">
                <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 flex items-center gap-3">
                    <i class="bi bi-list-ul text-purple-600"></i>
                    @(IsEditMode ? Localizer["EditLookup"] : Localizer["CreateLookup"]) 
                </h1>
            </div>

            @if (isLoading)
            {
                <div class="flex justify-center items-center py-12">
                    <svg class="animate-spin h-10 w-10 text-purple-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                </div>
            }
            else
            {
                <EditForm Model="@model" OnValidSubmit="@HandleSubmit" FormName="lookupForm">
                    <LocalizedDataAnnotationsValidator />
                    <ServerValidator @ref="serverValidator" />

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg flex items-start gap-3">
                            <i class="bi bi-exclamation-triangle-fill text-red-600 text-lg mt-0.5"></i>
                            <span class="text-red-800">@errorMessage</span>
                        </div>
                    }

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                        <div>
                            <label for="code" class="block text-sm font-medium text-gray-700 mb-2">@Localizer["Code"]</label>
                            <InputText @bind-Value="model.Code" 
                                       class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-all duration-200" 
                                       id="code" 
                                       placeholder="e.g. SA, RUH" />
                            <ValidationMessage For="@(() => model.Code)" class="text-red-600 text-sm mt-1" />
                        </div>

                        <div>
                            <label for="type" class="block text-sm font-medium text-gray-700 mb-2">@Localizer["Type"]</label>
                            <InputSelect @bind-Value="model.Type" 
                                         class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-all duration-200" 
                                         id="type">
                                <option value="">@Localizer["SelectType"]</option>
                                @foreach (var (value, label) in lookupTypes)
                                {
                                    <option value="@value">@label</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="@(() => model.Type)" class="text-red-600 text-sm mt-1" />
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                        <div>
                            <label for="nameEn" class="block text-sm font-medium text-gray-700 mb-2">@Localizer["NameEn"]</label>
                            <InputText @bind-Value="model.NameEn" 
                                       class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-all duration-200" 
                                       id="nameEn" 
                                       placeholder="e.g. Saudi Arabia" />
                            <ValidationMessage For="@(() => model.NameEn)" class="text-red-600 text-sm mt-1" />
                        </div>

                        <div>
                            <label for="nameAr" class="block text-sm font-medium text-gray-700 mb-2">@Localizer["NameAr"]</label>
                            <InputText @bind-Value="model.NameAr" 
                                       class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-all duration-200" 
                                       id="nameAr" 
                                       placeholder="e.g. السعودية" />
                            <ValidationMessage For="@(() => model.NameAr)" class="text-red-600 text-sm mt-1" />
                        </div>
                            </div>

                        <div class="mb-6">
                            <label for="parentId" class="block text-sm font-medium text-gray-700 mb-2">@Localizer["ParentLookup"] <span class="text-gray-400 text-xs">(@Localizer["Optional"])</span></label>
                            <InputSelect @bind-Value="model.ParentId" 
                                         class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-all duration-200" 
                                         id="parentId">
                                <option value="">@Localizer["NoParent"]</option>
                                @foreach (var lookup in availableParentLookups)
                                {
                                    <option value="@lookup.Id">@(isAr ? lookup.NameAr : lookup.NameEn) (@lookup.Type)</option>
                                }
                            </InputSelect>
                        </div>

                            <div class="mb-6">
                                 <Checkbox @bind-Value="model.IsActive" Label="@Localizer["Active"]" />
                    </div>

                    <div class="flex items-center justify-end gap-3 pt-6 border-t border-gray-200">
                        @if (IsEditMode && currentLookup != null)
                        {
                            <div class="text-sm text-gray-500 me-auto">
                                <div class="flex flex-col gap-1">
                                    <div>
                                        <i class="bi bi-clock-history me-1"></i>
                                        @Localizer["CreatedAt"]: @currentLookup.CreatedAt.ToString("dd MMM yyyy, HH:mm")
                                    </div>
                                    @if (currentLookup.UpdatedAt.HasValue)
                                    {
                                        <div>
                                            <i class="bi bi-pencil-square me-1"></i>
                                            @Localizer["UpdatedAt"]: @currentLookup.UpdatedAt.Value.ToString("dd MMM yyyy, HH:mm")
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                        <button type="button" 
                                @onclick="Cancel" 
                                class="px-6 py-3 bg-white border border-gray-300 text-gray-700 font-medium rounded-lg hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500 transition-colors duration-200">
                            @Localizer["Cancel"]
                        </button>
                        <button type="submit" 
                                class="px-6 py-3 bg-gradient-to-r from-purple-600 to-purple-800 text-white font-medium rounded-lg hover:from-purple-700 hover:to-purple-900 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500 transition-all duration-200 shadow-lg hover:shadow-xl disabled:opacity-50 disabled:cursor-not-allowed flex items-center gap-2"
                                disabled="@isSaving">
                            @if (isSaving)
                            {
                                <svg class="animate-spin -ms-1 me-3 h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                                </svg>
                                <span>@Localizer["Processing"]</span>
                            }
                            else
                            {
                                <span>@Localizer["Save"]</span>
                            }
                        </button>
                    </div>
                </EditForm>
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public Guid? LookupId { get; set; }

    private bool IsEditMode => LookupId.HasValue && LookupId.Value != Guid.Empty;
    
    private LookupFormModel model = new();
    private List<LookupDto> availableParentLookups = new();
    private bool isLoading = true;
    private bool isSaving = false;
    private string errorMessage = string.Empty;
    private ServerValidator serverValidator = null!;
    private LookupDto? currentLookup;
    private string? originalCode;
    private string? originalNameEn;
    private string? originalNameAr;

    // dynamic lookup types list
    private List<(string Value, string Label)> lookupTypes = new();

    protected override async Task OnInitializedAsync()
    {
        BuildLookupTypes();
        await LoadAvailableParentLookups();
        
        if (IsEditMode)
        {
            await LoadLookup();
        }
        
        isLoading = false;
    }

    private void BuildLookupTypes()
    {
        isAr = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName.Equals("ar", StringComparison.OrdinalIgnoreCase);
        // Include all lookup types except Unknown
        lookupTypes = Enum.GetValues<LookupType>()
            .Where(t => t != LookupType.Unknown)
            .Select(t => (
                Value: t.ToString(),
                Label: Localizer[t.ToString()] ?? t.ToString()
            ))
            .ToList();
    }

    private bool isAr = false;

    private async Task LoadAvailableParentLookups()
    {
        try
        {
            // Load all active lookups that can be used as parents
            var allLookups = await LookupService.GetAllLookupsAsync(1, 1000);
            availableParentLookups = allLookups.Items
                .Where(l => l.IsActive && (!IsEditMode || l.Id != LookupId))
                .OrderBy(l => l.Type)
                .ThenBy(l => isAr ? l.NameAr : l.NameEn)
                .ToList();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load parent lookups: {ex.Message}";
        }
    }

    private async Task LoadLookup()
    {
        try
        {
            var lookup = await LookupService.GetLookupByIdAsync(LookupId!.Value);
            if (lookup != null)
            {
                currentLookup = lookup;
                model = new LookupFormModel
                {
                    Code = lookup.Code,
                    NameEn = lookup.NameEn,
                    NameAr = lookup.NameAr,
                    Type = lookup.Type,
                    ParentId = lookup.ParentId,
                    IsActive = lookup.IsActive
                };
                
                // Set the original values for comparison
                originalCode = lookup.Code;
                originalNameEn = lookup.NameEn;
                originalNameAr = lookup.NameAr;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load lookup: {ex.Message}";
        }
    }

    private async Task HandleSubmit()
    {
        isSaving = true;
        errorMessage = string.Empty;

        try
        {
            // Check if any values have changed that need uniqueness validation
            bool codeChanged = !IsEditMode || !string.Equals(originalCode, model.Code, StringComparison.OrdinalIgnoreCase);
            bool nameEnChanged = !IsEditMode || !string.Equals(originalNameEn, model.NameEn, StringComparison.OrdinalIgnoreCase);
            bool nameArChanged = !IsEditMode || !string.Equals(originalNameAr, model.NameAr, StringComparison.OrdinalIgnoreCase);

            if (codeChanged || nameEnChanged || nameArChanged)
            {
                var (codeExists, nameEnExists, nameArExists) = await LookupService.CheckLookupExistsAsync(
                    model.Code, model.NameEn, model.NameAr, IsEditMode ? LookupId : null);

                var errors = new Dictionary<string, string[]>();

                if (codeChanged && codeExists)
                {
                    errors[nameof(model.Code)] = new[] { Localizer["LookupCodeAlreadyExists"] };
                }
                if (nameEnChanged && nameEnExists)
                {
                    errors[nameof(model.NameEn)] = new[] { Localizer["LookupNameEnAlreadyExists"] };
                }
                if (nameArChanged && nameArExists)
                {
                    errors[nameof(model.NameAr)] = new[] { Localizer["LookupNameArAlreadyExists"] };
                }

                if (errors.Any())
                {
                    serverValidator.DisplayErrors(errors);
                    isSaving = false;
                    return;
                }
            }

            if (IsEditMode)
            {
                var updateRequest = new UpdateLookupRequest
                {
                    Code = model.Code,
                    NameEn = model.NameEn,
                    NameAr = model.NameAr,
                    Type = model.Type,
                    ParentId = model.ParentId,
                    IsActive = model.IsActive
                };
                
                await LookupService.UpdateLookupAsync(LookupId!.Value, updateRequest);
            }
            else
            {
                var createRequest = new CreateLookupRequest
                {
                    Code = model.Code,
                    NameEn = model.NameEn,
                    NameAr = model.NameAr,
                    Type = model.Type,
                    ParentId = model.ParentId,
                    IsActive = model.IsActive
                };
                
                await LookupService.CreateLookupAsync(createRequest);
            }

            Navigation.NavigateTo("/admin/lookups");
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to save lookup: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/admin/lookups");
    }

    private class LookupFormModel
    {
        [Required(ErrorMessage = "CodeRequired")]
        public string Code { get; set; } = string.Empty;
        
        [Required(ErrorMessage = "NameRequired")]
        public string NameEn { get; set; } = string.Empty;
        
        [Required(ErrorMessage = "NameRequired")]
        public string NameAr { get; set; } = string.Empty;
        
        [Required(ErrorMessage = "Required")]
        public string Type { get; set; } = string.Empty;
        
        public Guid? ParentId { get; set; }
        public bool IsActive { get; set; } = true;
    }
}
