@page "/admin/roles"
@attribute [Authorize]
@attribute [RequirePermission(Permissions.RolesRead)]
@using Microsoft.AspNetCore.Authorization
@using Web.Authorization
@using Web.Components.Common
@using System.Globalization
@inject IRoleManagementService RoleService
@inject NavigationManager Navigation
@inject IJsonStringLocalizer Localizer

<PageTitle>@Localizer["RolesManagement"]</PageTitle>

<div class="min-h-screen bg-gray-50 py-4 sm:py-8 px-2 sm:px-4">
    <div class="max-w-7xl mx-auto">
        <div class="bg-white rounded-2xl shadow-lg p-4 sm:p-8">
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4 mb-8">
                <div>
                    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 flex items-center gap-3">
                        <i class="bi bi-shield-check text-bf-primary"></i>
                        @Localizer["RolesManagement"]
                    </h1>
                    <p class="text-gray-600 mt-2 text-sm sm:text-base">@Localizer["ManageSystemRolesPermissions"]</p>
                </div>
                <AuthorizeView Policy="Permission:roles.write">
                    <Authorized>
                        <button @onclick="NavigateToCreate" 
                                class="inline-flex items-center gap-2 py-3 px-6 bg-bf-primary text-bf-primary-contrast rounded-lg hover:opacity-90 transition-all duration-200 shadow-lg hover:shadow-xl font-medium">
                            <i class="bi bi-plus-circle"></i>
                            <span>@Localizer["AddRole"]</span>
                        </button>
                    </Authorized>
                    <NotAuthorized>
                        <button disabled 
                                class="inline-flex items-center gap-2 py-3 px-6 bg-gray-300 text-gray-500 rounded-lg cursor-not-allowed font-medium">
                            <i class="bi bi-plus-circle"></i>
                            <span>@Localizer["AddRole"]</span>
                        </button>
                    </NotAuthorized>
                </AuthorizeView>
            </div>

            @if (isLoading)
            {
                <div class="flex justify-center items-center py-12">
                    <svg class="animate-spin h-10 w-10 text-bf-primary" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                </div>
            }
            else
            {
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg flex items-start gap-3">
                        <i class="bi bi-exclamation-triangle-fill text-red-600 text-lg mt-0.5"></i>
                        <span class="text-red-800">@errorMessage</span>
                        <button @onclick="ClearError" class="ms-auto text-red-600 hover:text-red-800">
                            <i class="bi bi-x-lg"></i>
                        </button>
                    </div>
                }

                @if (roles == null || !roles.Any())
            {
                <div class="text-center py-12">
                    <i class="bi bi-inbox text-6xl text-gray-300 mb-4"></i>
                    <p class="text-gray-500 text-lg">@Localizer["NoRolesFound"]</p>
                </div>
            }
            else
            {
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-6">
                    @foreach (var role in roles)
                    {
                        <div class="bg-white border border-gray-200 rounded-xl p-6 hover:shadow-lg transition-shadow duration-200">
                            <div class="flex justify-between items-start mb-4">
                                <div class="flex-shrink-0 h-12 w-12 bg-bf-primary/10 rounded-lg flex items-center justify-center">
                                    <i class="bi bi-shield-check text-bf-primary text-2xl"></i>
                                </div>
                                <div class="flex gap-1">
                                    <AuthorizeView Policy="Permission:system.audit">
                                        <Authorized>
                                            <button @onclick="() => ViewLogs(role.Id)" 
                                                    class="p-2 text-amber-600 hover:text-amber-700 hover:bg-amber-50 rounded-lg transition-all duration-200" 
                                                    title="@Localizer["ViewLogs"]">
                                                <i class="bi bi-journal-text"></i>
                                            </button>
                                        </Authorized>
                                    </AuthorizeView>
                                    <AuthorizeView Policy="Permission:roles.write">
                                        <Authorized>
                                            @if (!role.IsSystemRole)
                                            {
                                                <button @onclick="() => NavigateToEdit(role.Id)" 
                                                        class="p-2 text-sky-600 hover:text-sky-700 hover:bg-sky-50 rounded-lg transition-all duration-200" 
                                                        title="@Localizer["Edit"]">
                                                    <i class="bi bi-pencil-square"></i>
                                                </button>
                                            }
                                            else
                                            {
                                                <button @onclick="() => NavigateToEdit(role.Id)" 
                                                        class="p-2 text-teal-600 hover:text-teal-700 hover:bg-teal-50 rounded-lg transition-all duration-200" 
                                                        title="@Localizer["ViewDetails"]">
                                                    <i class="bi bi-eye"></i>
                                                </button>
                                            }
                                        </Authorized>
                                        <NotAuthorized>
                                            @if (role.IsSystemRole)
                                            {
                                                <button @onclick="() => NavigateToEdit(role.Id)" 
                                                        class="p-2 text-teal-600 hover:text-teal-700 hover:bg-teal-50 rounded-lg transition-all duration-200" 
                                                        title="@Localizer["ViewDetails"]">
                                                    <i class="bi bi-eye"></i>
                                                </button>
                                            }
                                            else
                                            {
                                                <button disabled class="p-2 text-gray-300 cursor-not-allowed">
                                                    <i class="bi bi-pencil-square"></i>
                                                </button>
                                            }
                                        </NotAuthorized>
                                    </AuthorizeView>
                                    @if (!role.IsSystemRole)
                                    {
                                        <AuthorizeView Policy="Permission:roles.delete">
                                            <Authorized>
                                                <button @onclick="() => ConfirmDelete(role)" 
                                                        class="p-2 text-rose-600 hover:text-rose-700 hover:bg-rose-50 rounded-lg transition-all duration-200"
                                                        title="@Localizer["Delete"]">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </Authorized>
                                            <NotAuthorized>
                                                <button disabled class="p-2 text-gray-300 cursor-not-allowed">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </NotAuthorized>
                                        </AuthorizeView>
                                    }
                                </div>
                            </div>
                            
                            <h3 class="text-lg font-bold text-gray-900 mb-1">
                                @(CultureInfo.CurrentUICulture.Name.StartsWith("ar", StringComparison.OrdinalIgnoreCase) ? role.NameAr : role.NameEn)
                            </h3>
                            
                            @{
                                var description = CultureInfo.CurrentUICulture.Name.StartsWith("ar", StringComparison.OrdinalIgnoreCase) 
                                    ? role.DescriptionAr 
                                    : role.DescriptionEn;
                            }
                            @if (!string.IsNullOrEmpty(description))
                            {
                                <p class="text-gray-600 text-sm mb-4 line-clamp-2">@description</p>
                            }
                            
                            <div class="flex items-center justify-between pt-4 border-t border-gray-200">
                                <div class="flex items-center gap-4">
                                    <div class="text-center">
                                        <p class="text-2xl font-bold text-bf-primary">@role.UserCount</p>
                                        <p class="text-xs text-gray-500">@Localizer["Users"]</p>
                                    </div>
                                    <div class="text-center">
                                        <p class="text-2xl font-bold text-bf-primary">@role.PermissionCount</p>
                                        <p class="text-xs text-gray-500">@Localizer["Permissions"]</p>
                                    </div>
                                </div>
                                
                                @if (role.IsSystemRole)
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                                        <i class="bi bi-lock-fill me-1"></i> @Localizer["SystemRole"]
                                    </span>
                                }
                            </div>
                        </div>
                    }
                </div>
                <Pagination PageIndex="@pageIndex" 
                            TotalPages="@totalPages" 
                            TotalCount="@totalCount" 
                            PageSize="@pageSize" 
                            OnPageChanged="@OnPageChanged" />
            }
            }
        </div>
    </div>
</div>

<AuthorizeView Policy="Permission:roles.delete">
    <Authorized>
        @if (showDeleteConfirm)
        {
            <div class="fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full z-50 flex items-center justify-center">
                <div class="bg-white rounded-xl shadow-2xl p-8 max-w-md w-full mx-4">
                    <h3 class="text-xl font-bold text-gray-900 mb-4">@Localizer["ConfirmDeleteRoleTitle"]</h3>
                    
                    @if (!string.IsNullOrEmpty(deleteErrorMessage))
                    {
                        <div class="mb-4 p-4 bg-red-50 border border-red-200 rounded-lg flex items-start gap-3">
                            <i class="bi bi-exclamation-triangle-fill text-red-600 text-lg mt-0.5"></i>
                            <span class="text-red-800 text-sm">@deleteErrorMessage</span>
                        </div>
                        <div class="flex gap-3">
                            <button @onclick="CancelDelete" 
                                    class="flex-1 py-2 px-4 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition-colors duration-200 font-medium">
                                @Localizer["Close"]
                            </button>
                        </div>
                    }
                    else
                    {
                        <p class="text-gray-600 mb-6">@Localizer["ConfirmDeleteRoleMessage"]</p>
                        <div class="flex gap-3">
                            <button @onclick="CancelDelete" 
                                    class="flex-1 py-2 px-4 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition-colors duration-200 font-medium">
                                @Localizer["Cancel"]
                            </button>
                            <button @onclick="DeleteRole" 
                                    class="flex-1 py-2 px-4 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors duration-200 font-medium">
                                @Localizer["Delete"]
                            </button>
                        </div>
                    }
                </div>
            </div>
        }
    </Authorized>
</AuthorizeView>

@code {
    private List<RoleResponse> roles = new();
    private bool isLoading = true;
    private string errorMessage = string.Empty;
    private string deleteErrorMessage = string.Empty;
    private bool showDeleteConfirm = false;
    private Guid roleToDelete;
    
    // Pagination
    private int pageIndex = 1;
    private int pageSize = 10;
    private int totalPages = 1;
    private int totalCount = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadRoles();
    }

    private async Task LoadRoles()
    {
        isLoading = true;
        errorMessage = string.Empty;
        
        try
        {
            var result = await RoleService.GetAllRolesAsync(pageIndex, pageSize);
            roles = result.Items;
            totalPages = result.TotalPages;
            totalCount = result.TotalCount;
        }
        catch (Exception ex)
        {
            errorMessage = $"{Localizer["FailedToLoadRoles"]}: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
    
    private async Task OnPageChanged(int newPageIndex)
    {
        pageIndex = newPageIndex;
        await LoadRoles();
    }

    private void NavigateToCreate()
    {
        Navigation.NavigateTo("/admin/roles/create");
    }

    private void NavigateToEdit(Guid roleId)
    {
        Navigation.NavigateTo($"/admin/roles/edit/{roleId}");
    }

    private void ViewLogs(Guid roleId)
    {
        var uri = $"/admin/logs?entityName=Role&entityId={roleId}";
        Navigation.NavigateTo(uri, forceLoad: false);
    }

    private void ConfirmDelete(RoleResponse role)
    {
        deleteErrorMessage = string.Empty;
        
        // Check if role has assigned users - show error in modal
        if (role.UserCount > 0)
        {
            deleteErrorMessage = Localizer["RoleHasAssignedUsers"];
        }
        
        roleToDelete = role.Id;
        showDeleteConfirm = true;
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
        roleToDelete = Guid.Empty;
        deleteErrorMessage = string.Empty;
    }

    private void ClearError()
    {
        errorMessage = string.Empty;
    }

    private async Task DeleteRole()
    {
        try
        {
            await RoleService.DeleteRoleAsync(roleToDelete);
            showDeleteConfirm = false;
            deleteErrorMessage = string.Empty;
            await LoadRoles();
        }
        catch (Exception ex)
        {
            deleteErrorMessage = $"{Localizer["FailedToDeleteRole"]}: {ex.Message}";
        }
    }
}
