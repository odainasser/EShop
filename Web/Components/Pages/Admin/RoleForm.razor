@page "/admin/roles/create"
@page "/admin/roles/edit/{RoleId:guid}"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using System.ComponentModel.DataAnnotations
@inject IRoleManagementService RoleService
@inject IPermissionManagementService PermissionService
@inject NavigationManager Navigation
@inject IJsonStringLocalizer Localizer

<PageTitle>@(IsEditMode ? Localizer["EditRole"] : Localizer["CreateRole"]) - BitFlow</PageTitle>

<div class="min-h-screen bg-gray-50 py-4 sm:py-8 px-2 sm:px-4">
    <div class="max-w-4xl mx-auto">
        <div class="bg-white rounded-2xl shadow-lg p-4 sm:p-8">
            <div class="mb-8">
                <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 flex items-center gap-3">
                    <i class="bi bi-shield-plus text-purple-600"></i>
                    @(IsEditMode ? Localizer["EditRole"] : Localizer["CreateRole"])
                </h1>
            </div>

            @if (isLoading)
            {
                <div class="flex justify-center items-center py-12">
                    <svg class="animate-spin h-10 w-10 text-purple-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                </div>
            }
            else
            {
                <EditForm Model="@model" OnValidSubmit="@HandleSubmit" FormName="roleForm">
                    <LocalizedDataAnnotationsValidator />
                    <ServerValidator @ref="serverValidator" />

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg flex items-start gap-3">
                            <i class="bi bi-exclamation-triangle-fill text-red-600 text-lg mt-0.5"></i>
                            <span class="text-red-800">@errorMessage</span>
                        </div>
                    }

                    @* Insert system-role warning panel at top to match Users form *@
                    @if (IsEditMode && currentRole?.IsSystemRole == true)
                    {
                        <div class="mb-6 p-4 bg-yellow-50 border border-yellow-200 rounded-lg">
                            <div class="flex items-start gap-3">
                                <i class="bi bi-exclamation-triangle text-yellow-600 text-lg mt-0.5"></i>
                                <div>
                                    <p class="text-yellow-800 font-medium">@Localizer["SystemRole"]</p>
                                    <p class="text-yellow-700 text-sm">@Localizer["SystemRoleWarning"]</p>
                                </div>
                            </div>
                        </div>
                    }

                    <div class="mb-6">
                        <label for="name" class="block text-sm font-medium text-gray-700 mb-2">@Localizer["RoleName"]</label>
                        <InputText @bind-Value="model.NameEn" 
                                   class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-all duration-200" 
                                   id="name" 
                                   placeholder="@Localizer["RoleName"]"
                                   disabled="@(currentRole?.IsSystemRole == true)" />
                        <ValidationMessage For="@(() => model.NameEn)" class="text-red-600 text-sm mt-1" />
                    </div>

                    <div class="mb-6">
                        <label for="nameAr" class="block text-sm font-medium text-gray-700 mb-2">@Localizer["RoleNameAr"]</label>
                        <InputText @bind-Value="model.NameAr" 
                                   class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-all duration-200" 
                                   id="nameAr" 
                                   placeholder="@Localizer["RoleNameAr"]"
                                   disabled="@(currentRole?.IsSystemRole == true)" />
                        <ValidationMessage For="@(() => model.NameAr)" class="text-red-600 text-sm mt-1" />
                    </div>

                    <div class="mb-6">
                        <label for="descriptionEn" class="block text-sm font-medium text-gray-700 mb-2">@Localizer["RoleDescriptionEn"]</label>
                        <InputTextArea @bind-Value="model.DescriptionEn" 
                                       class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-all duration-200" 
                                       id="descriptionEn" 
                                       rows="3"
                                       placeholder="@Localizer["RoleDescriptionEnPlaceholder"]"
                                       disabled="@(currentRole?.IsSystemRole == true)" />
                        <ValidationMessage For="@(() => model.DescriptionEn)" class="text-red-600 text-sm mt-1" />
                    </div>

                    <div class="mb-6">
                        <label for="descriptionAr" class="block text-sm font-medium text-gray-700 mb-2">@Localizer["RoleDescriptionAr"]</label>
                        <InputTextArea @bind-Value="model.DescriptionAr" 
                                       class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-all duration-200" 
                                       id="descriptionAr" 
                                       rows="3"
                                       placeholder="@Localizer["RoleDescriptionArPlaceholder"]"
                                       disabled="@(currentRole?.IsSystemRole == true)" />
                        <ValidationMessage For="@(() => model.DescriptionAr)" class="text-red-600 text-sm mt-1" />
                    </div>

                    <div class="mb-6">
    <label class="block text-sm font-medium text-gray-700 mb-3">@Localizer["Permissions"]</label>
    <div class="space-y-2 max-h-96 overflow-y-auto border border-gray-200 rounded-lg p-4">
        @if (availablePermissions.Any())
        {
            @foreach (var group in availablePermissions.GroupBy(p => p.Module ?? "Other"))
            {
                <div class="mb-4">
                    <h3 class="text-sm font-semibold text-gray-900 mb-2 flex items-center gap-2">
                        <i class="bi bi-folder text-purple-600"></i>
                        @Localizer[$"Module_{group.Key}"]
                    </h3>
                    <div class="space-y-2 ml-6">
                        @foreach (var permission in group)
                        {
                            <label class="flex items-start p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors duration-200 cursor-pointer">
                                <Checkbox Value="@model.PermissionIds.Contains(permission.Id)" 
                                          ValueChanged="@((val) => TogglePermission(permission.Id, val))"
                                          Class="mt-1"
                                          Disabled="@(currentRole?.IsSystemRole == true)" />
                                <div class="ms-3 flex-1">
                                    <span class="text-sm font-medium text-gray-700">@(isAr ? permission.NameAr : permission.NameEn)</span>
                                    @if (!string.IsNullOrEmpty(isAr ? permission.DescriptionAr : permission.DescriptionEn))
                                    {
                                        <p class="text-xs text-gray-500 mt-1">@(isAr ? permission.DescriptionAr : permission.DescriptionEn)</p>
                                    }
                                </div>
                            </label>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <p class="text-gray-500 text-sm text-center py-4">@Localizer["NoPermissionsAvailable"]</p>
        }
    </div>
</div>

<div class="flex items-center justify-end gap-3 pt-6 border-t border-gray-200">
    @if (IsEditMode && currentRole != null)
    {
        <div class="text-sm text-gray-500 me-auto">
            <div class="flex flex-col gap-1">
                <div>
                    <i class="bi bi-clock-history me-1"></i>
                    @Localizer["CreatedAt"]: @currentRole.CreatedAt.ToString("dd MMM yyyy, HH:mm")
                </div>
                @if (currentRole.UpdatedAt.HasValue)
                {
                    <div>
                        <i class="bi bi-pencil-square me-1"></i>
                        @Localizer["UpdatedAt"]: @currentRole.UpdatedAt.Value.ToString("dd MMM yyyy, HH:mm")
                    </div>
                }
            </div>
        </div>
    }
    <button type="button" 
            @onclick="Cancel" 
            class="px-6 py-3 bg-white border border-gray-300 text-gray-700 font-medium rounded-lg hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500 transition-colors duration-200">
        @((currentRole?.IsSystemRole == true) ? Localizer["Close"] : Localizer["Cancel"])
    </button>
    
    @if (currentRole?.IsSystemRole != true)
    {
        <button type="submit" 
                class="px-6 py-3 bg-gradient-to-r from-purple-600 to-purple-800 text-white font-medium rounded-lg hover:from-purple-700 hover:to-purple-900 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500 transition-all duration-200 shadow-lg hover:shadow-xl disabled:opacity-50 disabled:cursor-not-allowed flex items-center gap-2"
                disabled="@isSaving">
            @if (isSaving)
            {
                <svg class="animate-spin -ms-1 me-3 h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                <span>@Localizer["Processing"]</span>
            }
            else
            {
                <span>@Localizer["Save"]</span>
            }
        </button>
    }
</div>
                </EditForm>
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public Guid? RoleId { get; set; }

    private bool IsEditMode => RoleId.HasValue && RoleId.Value != Guid.Empty;
    
    private RoleFormModel model = new();
    private RoleDetailResponse? currentRole;
    private List<PermissionDto> availablePermissions = new();
    private bool isLoading = true;
    private bool isSaving = false;
    private string errorMessage = string.Empty;
    private bool isAr = false;
    private ServerValidator serverValidator = null!;
    private string? originalNameEn;

    protected override async Task OnInitializedAsync()
    {
        isAr = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName.Equals("ar", StringComparison.OrdinalIgnoreCase);
        await LoadPermissions();
        
        if (IsEditMode)
        {
            await LoadRole();
        }
        
        isLoading = false;
    }

    private async Task LoadPermissions()
    {
        try
        {
            var permissions = await PermissionService.GetAllPermissionsAsync();
            availablePermissions = permissions.ToList();
        }
        catch (Exception ex)
        {
            errorMessage = $"{Localizer["FailedToLoadPermissions"]}: {ex.Message}";
        }
    }

    private async Task LoadRole()
    {
        try
        {
            currentRole = await RoleService.GetRoleByIdAsync(RoleId!.Value);
            if (currentRole != null)
            {
                model = new RoleFormModel
                {
                    NameEn = currentRole.NameEn,
                    NameAr = currentRole.NameAr,
                    DescriptionEn = currentRole.DescriptionEn,
                    DescriptionAr = currentRole.DescriptionAr,
                    PermissionIds = currentRole.Permissions.Select(p => p.Id).ToList(),
                    IsActive = currentRole.IsActive
                };
                originalNameEn = currentRole.NameEn; // Track original name for validation
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"{Localizer["FailedToLoadRole"]}: {ex.Message}";
        }
    }

    private void TogglePermission(Guid permissionId, bool isChecked)
    {
        if (isChecked)
        {
            if (!model.PermissionIds.Contains(permissionId))
            {
                model.PermissionIds.Add(permissionId);
            }
        }
        else
        {
            model.PermissionIds.Remove(permissionId);
        }
    }

    private async Task HandleSubmit()
    {
        isSaving = true;
        errorMessage = string.Empty;

        try
        {
            // Check if role name already exists
            if (!IsEditMode || (IsEditMode && !string.Equals(originalNameEn, model.NameEn, StringComparison.OrdinalIgnoreCase)))
            {
                var exists = await RoleService.CheckRoleNameExistsAsync(model.NameEn, IsEditMode ? RoleId : null);
                if (exists)
                {
                    serverValidator.DisplayErrors(new Dictionary<string, string[]>
                    {
                        { nameof(model.NameEn), new[] { Localizer["RoleAlreadyExists"] } }
                    });
                    isSaving = false;
                    return;
                }
            }

            if (IsEditMode)
            {
                var updateRequest = new UpdateRoleRequest
                {
                    NameEn = model.NameEn,
                    NameAr = model.NameAr,
                    DescriptionEn = model.DescriptionEn,
                    DescriptionAr = model.DescriptionAr,
                    IsActive = model.IsActive
                };
                
                await RoleService.UpdateRoleAsync(RoleId!.Value, updateRequest);
                
                // Assign permissions separately
                var assignPermissionsRequest = new AssignPermissionsRequest
                {
                    PermissionIds = model.PermissionIds
                };
                await RoleService.AssignPermissionsToRoleAsync(RoleId!.Value, assignPermissionsRequest);
            }
            else
            {
                var createRequest = new CreateRoleRequest
                {
                    NameEn = model.NameEn,
                    NameAr = model.NameAr,
                    DescriptionEn = model.DescriptionEn,
                    DescriptionAr = model.DescriptionAr,
                    IsSystemRole = false,
                    IsActive = model.IsActive
                };
                
                var createdRole = await RoleService.CreateRoleAsync(createRequest);
                
                // Assign permissions to newly created role
                if (model.PermissionIds.Any())
                {
                    var assignPermissionsRequest = new AssignPermissionsRequest
                    {
                        PermissionIds = model.PermissionIds
                    };
                    await RoleService.AssignPermissionsToRoleAsync(createdRole.Id, assignPermissionsRequest);
                }
            }

            Navigation.NavigateTo("/admin/roles");
        }
        catch (Exception ex)
        {
            errorMessage = $"{Localizer["FailedToSaveRole"]}: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/admin/roles");
    }

    private class RoleFormModel
    {
        [Required(ErrorMessage = "RoleNameRequired")]
        public string NameEn { get; set; } = string.Empty;
        
        [Required(ErrorMessage = "RoleNameArRequired")]
        public string NameAr { get; set; } = string.Empty;
        
        public string? DescriptionEn { get; set; }
        public string? DescriptionAr { get; set; }
        public List<Guid> PermissionIds { get; set; } = new();
        public bool IsActive { get; set; } = true;
    }
}
