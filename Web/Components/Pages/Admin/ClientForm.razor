@page "/admin/clients/edit/{ClientId:guid}"
@attribute [Authorize]
@attribute [RequirePermission(Permissions.ClientsRead)]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using System.ComponentModel.DataAnnotations
@using Web.Authorization
@inject IUserManagementService UserService
@inject IMediaService MediaService
@inject NavigationManager Navigation
@inject IJsonStringLocalizer Localizer

<PageTitle>@Localizer["EditClient"]</PageTitle>

<div class="min-h-screen bg-gray-50 py-4 sm:py-8 px-2 sm:px-4">
    <div class="max-w-4xl mx-auto">
        <div class="bg-white rounded-2xl shadow-lg p-4 sm:p-8">
            <div class="mb-8">
                <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 flex items-center gap-3">
                    <i class="bi bi-person-badge text-bf-primary"></i>
                    @Localizer["EditClient"]
                </h1>
                <p class="text-gray-600 mt-2">@Localizer["ManageClientAccountDetails"]</p>
            </div>

            @if (isLoading)
            {
                <div class="flex justify-center items-center py-12">
                    <svg class="animate-spin h-10 w-10 text-bf-primary" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                </div>
            }
            else if (currentClient == null)
            {
                <div class="text-center py-12">
                    <i class="bi bi-exclamation-circle text-6xl text-gray-300 mb-4"></i>
                    <p class="text-gray-500 text-lg">@Localizer["ClientNotFound"]</p>
                    <button @onclick="GoBack" class="mt-4 px-6 py-3 bg-bf-primary text-bf-primary-contrast rounded-lg hover:opacity-90 transition-all duration-200">
                        @Localizer["Back"]
                    </button>
                </div>
            }
            else
            {
                <EditForm Model="@model" OnValidSubmit="@HandleSubmit" FormName="clientForm">
                    <LocalizedDataAnnotationsValidator />
                    <ServerValidator @ref="serverValidator" />

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg flex items-start gap-3">
                            <i class="bi bi-exclamation-triangle-fill text-red-600 text-lg mt-0.5"></i>
                            <span class="text-red-800">@errorMessage</span>
                        </div>
                    }

                    @if (isSystemUser)
                    {
                        <div class="mb-4 p-4 bg-yellow-50 border border-yellow-200 rounded-lg flex items-start gap-3">
                            <i class="bi bi-lock-fill text-yellow-600 text-lg mt-0.5"></i>
                            <span class="text-yellow-800">@Localizer["SystemUserCannotBeModified"]</span>
                        </div>
                    }

                    <!-- Profile Picture -->
                    <div class="mb-6">
                        <label class="block text-sm font-medium text-gray-700 mb-2">@Localizer["ProfilePicture"]</label>
                        <div class="flex items-center gap-4">
                            @if (!string.IsNullOrEmpty(avatarUrl))
                            {
                                <img src="@avatarUrl" alt="Profile Picture" class="h-20 w-20 rounded-full object-cover border border-gray-200" />
                            }
                            else
                            {
                                <div class="h-20 w-20 rounded-full bg-gray-100 flex items-center justify-center border border-gray-200">
                                    <i class="bi bi-person text-3xl text-gray-400"></i>
                                </div>
                            }

                            <AuthorizeView Policy="Permission:clients.write">
                                <Authorized Context="authContext">
                                    @if (!isSystemUser)
                                    {
                                        <div>
                                            <InputFile OnChange="HandleFileSelected" class="block w-full text-sm text-gray-500" />
                                        </div>
                                    }
                                </Authorized>
                            </AuthorizeView>
                        </div>
                    </div>

                    <!-- Name Fields -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                        <div>
                            <label for="firstName" class="block text-sm font-medium text-gray-700 mb-2">@Localizer["FirstName"]</label>
                            <InputText @bind-Value="model.FirstName" 
                                       class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-bf-primary/50 focus:border-bf-primary transition-all duration-200 disabled:bg-gray-100 disabled:cursor-not-allowed" 
                                       id="firstName" 
                                       disabled="@(!canEdit)" />
                            <ValidationMessage For="@(() => model.FirstName)" class="text-red-600 text-sm mt-1" />
                        </div>

                        <div>
                            <label for="lastName" class="block text-sm font-medium text-gray-700 mb-2">@Localizer["LastName"]</label>
                            <InputText @bind-Value="model.LastName" 
                                       class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-bf-primary/50 focus:border-bf-primary transition-all duration-200 disabled:bg-gray-100 disabled:cursor-not-allowed" 
                                       id="lastName" 
                                       disabled="@(!canEdit)" />
                            <ValidationMessage For="@(() => model.LastName)" class="text-red-600 text-sm mt-1" />
                        </div>
                    </div>

                    <!-- Email -->
                    <div class="mb-6">
                        <label for="email" class="block text-sm font-medium text-gray-700 mb-2">@Localizer["Email"]</label>
                        <InputText @bind-Value="model.Email" 
                                   class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-bf-primary/50 focus:border-bf-primary transition-all duration-200 disabled:bg-gray-100 disabled:cursor-not-allowed" 
                                   id="email" 
                                   disabled="@(!canEdit)" />
                        <ValidationMessage For="@(() => model.Email)" class="text-red-600 text-sm mt-1" />
                    </div>

                    <!-- Phone Number -->
                    <div class="mb-6">
                        <label for="phoneNumber" class="block text-sm font-medium text-gray-700 mb-2">@Localizer["PhoneNumber"]</label>
                        <InputText @bind-Value="model.PhoneNumber" 
                                   class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-bf-primary/50 focus:border-bf-primary transition-all duration-200 disabled:bg-gray-100 disabled:cursor-not-allowed" 
                                   id="phoneNumber" 
                                   disabled="@(!canEdit)" />
                        <ValidationMessage For="@(() => model.PhoneNumber)" class="text-red-600 text-sm mt-1" />
                    </div>

                    <!-- Active Status -->
                    <div class="mb-8">
                        <Checkbox Id="isActive" @bind-Value="model.IsActive" Disabled="@(!canEdit)" Label="@Localizer["Active"]" />
                    </div>

                    <!-- Footer with timestamps and actions -->
                    <div class="flex items-center justify-end gap-3 pt-6 border-t border-gray-200">
                        @if (currentClient != null)
                        {
                            <div class="text-sm text-gray-500 me-auto">
                                <div class="flex flex-col gap-1">
                                    <div>
                                        <i class="bi bi-clock-history me-1"></i>
                                        @Localizer["CreatedAt"]: @currentClient.CreatedAt.ToString("dd MMM yyyy, HH:mm")
                                    </div>
                                    @if (currentClient.UpdatedAt.HasValue)
                                    {
                                        <div>
                                            <i class="bi bi-pencil-square me-1"></i>
                                            @Localizer["UpdatedAt"]: @currentClient.UpdatedAt.Value.ToString("dd MMM yyyy, HH:mm")
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                        <button type="button" @onclick="GoBack" class="px-6 py-3 bg-white border border-gray-300 text-gray-700 font-medium rounded-lg hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-bf-primary transition-colors duration-200">
                            @(canEdit ? Localizer["Cancel"] : Localizer["Close"])
                        </button>
                        <AuthorizeView Policy="Permission:clients.write">
                            <Authorized Context="authContext">
                                @if (canEdit)
                                {
                                    <button type="submit" disabled="@isSubmitting" class="px-6 py-3 bg-bf-primary text-bf-primary-contrast font-medium rounded-lg hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-bf-primary transition-all duration-200 shadow-lg hover:shadow-xl disabled:opacity-50 disabled:cursor-not-allowed flex items-center gap-2">
                                        @if (isSubmitting)
                                        {
                                            <svg class="animate-spin -ms-1 me-3 h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                                            </svg>
                                            <span>@Localizer["Processing"]</span>
                                        }
                                        else
                                        {
                                            <span>@Localizer["Save"]</span>
                                        }
                                    </button>
                                }
                            </Authorized>
                        </AuthorizeView>
                    </div>
                </EditForm>
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public Guid ClientId { get; set; }

    private ClientFormModel model = new();
    private bool isLoading = true;
    private bool isSubmitting = false;
    private string errorMessage = string.Empty;
    private string? avatarUrl;
    private IBrowserFile? selectedAvatarFile;
    private bool isSystemUser = false;
    private bool canEdit => !isSystemUser;
    private string? originalEmail;
    private ServerValidator serverValidator = null!;
    private UserResponse? currentClient;

    protected override async Task OnInitializedAsync()
    {
        await LoadClient();
    }

    private async Task LoadClient()
    {
        isLoading = true;
        try
        {
            var client = await UserService.GetUserByIdAsync(ClientId);
            if (client != null)
            {
                // Verify this is actually a client user
                var isClient = client.Roles.Any(r => string.Equals(r.Name, "Client", StringComparison.OrdinalIgnoreCase));
                if (!isClient)
                {
                    // Not a client, redirect to users
                    Navigation.NavigateTo("/admin/clients");
                    return;
                }

                currentClient = client;
                model = new ClientFormModel
                {
                    FirstName = client.FirstName ?? string.Empty,
                    LastName = client.LastName ?? string.Empty,
                    Email = client.Email,
                    PhoneNumber = client.PhoneNumber,
                    IsActive = client.IsActive
                };
                originalEmail = client.Email;
                
                // Get avatar
                var media = await MediaService.GetMediaForEntityAsync(ClientId, "User", "avatar");
                var avatar = media.FirstOrDefault();
                if (avatar != null)
                {
                    avatarUrl = MediaService.GetMediaUrl(avatar);
                }

                isSystemUser = client.IsSystemUser;
            }
        }
        catch (Exception ex)
        {
            errorMessage = Localizer["FailedToLoadClient"] + $": {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleSubmit()
    {
        if (!canEdit) return;
        
        errorMessage = string.Empty;
        isSubmitting = true;

        try
        {
            // Check if email exists (only if changed)
            if (!string.Equals(originalEmail, model.Email, StringComparison.OrdinalIgnoreCase))
            {
                var exists = await UserService.CheckEmailExistsAsync(model.Email);
                if (exists)
                {
                    string msg = Localizer["UserAlreadyExists"];
                    if (string.IsNullOrEmpty(msg) || msg == "UserAlreadyExists")
                    {
                        msg = $"User with email '{model.Email}' already exists.";
                    }
                    
                    serverValidator.DisplayErrors(new Dictionary<string, string[]> 
                    {
                        { nameof(model.Email), new[] { msg } }
                    });

                    isSubmitting = false;
                    return;
                }
            }

            var updateRequest = new UpdateUserRequest
            {
                FirstName = model.FirstName,
                LastName = model.LastName,
                Email = model.Email,
                PhoneNumber = model.PhoneNumber,
                IsActive = model.IsActive
            };

            await UserService.UpdateUserAsync(ClientId, updateRequest);
            
            // Note: We do NOT call AssignRolesToUserAsync because client role cannot be changed

            // Upload avatar after successful update
            await UploadSelectedAvatarAsync();

            Navigation.NavigateTo("/admin/clients");
        }
        catch (ServerValidationException ex)
        {
            serverValidator.DisplayErrors(ex.Errors);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task UploadSelectedAvatarAsync()
    {
        if (selectedAvatarFile == null) return;

        long maxFileSize = 5 * 1024 * 1024;
        using var uploadStream = selectedAvatarFile.OpenReadStream(maxFileSize);

        var existingMedia = await MediaService.GetMediaForEntityAsync(ClientId, "User", "avatar");
        foreach (var media in existingMedia)
        {
            await MediaService.DeleteMediaAsync(media.Id);
        }

        var uploaded = await MediaService.UploadMediaAsync(ClientId, "User", uploadStream, selectedAvatarFile.Name, selectedAvatarFile.ContentType, "avatar");
        avatarUrl = MediaService.GetMediaUrl(uploaded);
        selectedAvatarFile = null;
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        if (!canEdit) return;

        var file = e.File;
        if (file == null) return;

        try
        {
            long maxFileSize = 5 * 1024 * 1024;
            // create preview
            try
            {
                var buffer = new byte[file.Size > int.MaxValue ? int.MaxValue : (int)file.Size];
                using var stream = file.OpenReadStream(maxFileSize);
                await stream.ReadAsync(buffer.AsMemory(0, buffer.Length));
                var base64 = Convert.ToBase64String(buffer);
                avatarUrl = $"data:{file.ContentType};base64,{base64}";
            }
            catch
            {
                // ignore preview errors
            }

            selectedAvatarFile = file;
        }
        catch (Exception ex)
        {
            errorMessage = Localizer["FailedToProcessImage"] + $": {ex.Message}";
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/admin/clients");
    }

    private class ClientFormModel
    {
        [Required(ErrorMessage = "FirstNameRequired")]
        public string FirstName { get; set; } = string.Empty;

        [Required(ErrorMessage = "LastNameRequired")]
        public string LastName { get; set; } = string.Empty;

        [Required(ErrorMessage = "EmailRequired")]
        [EmailAddress(ErrorMessage = "InvalidEmailFormat")]
        public string Email { get; set; } = string.Empty;

        public string? PhoneNumber { get; set; }
        public bool IsActive { get; set; } = true;
    }
}
