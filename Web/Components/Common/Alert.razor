@* Reusable alert/message component *@
@if (!string.IsNullOrEmpty(Message))
{
    <div class="@GetAlertClass() mb-6 p-4 rounded-lg flex items-start gap-3">
        <i class="@GetIconClass() text-lg mt-0.5"></i>
        <div class="flex-1">
            <span class="@GetTextClass()">@Message</span>
            @if (Dismissible)
            {
                <button type="button" class="@GetDismissButtonClass()" @onclick="Dismiss">
                    <i class="bi bi-x-lg"></i>
                </button>
            }
        </div>
    </div>
}

@code {
    [Parameter] public string? Message { get; set; }
    [Parameter] public AlertType Type { get; set; } = AlertType.Info;
    [Parameter] public bool Dismissible { get; set; } = true;
    [Parameter] public EventCallback OnDismiss { get; set; }

    private async Task Dismiss()
    {
        Message = null;
        await OnDismiss.InvokeAsync();
    }

    private string GetAlertClass() => Type switch
    {
        AlertType.Success => "bg-green-50 border border-green-200",
        AlertType.Error => "bg-red-50 border border-red-200",
        AlertType.Warning => "bg-yellow-50 border border-yellow-200",
        _ => "bg-bf-primary/10 border border-bf-primary/30"
    };

    private string GetIconClass() => Type switch
    {
        AlertType.Success => "bi bi-check-circle-fill text-green-600",
        AlertType.Error => "bi bi-exclamation-triangle-fill text-red-600",
        AlertType.Warning => "bi bi-exclamation-triangle-fill text-yellow-600",
        _ => "bi bi-info-circle-fill text-bf-primary"
    };

    private string GetTextClass() => Type switch
    {
        AlertType.Success => "text-green-800",
        AlertType.Error => "text-red-800",
        AlertType.Warning => "text-yellow-800",
        _ => "text-bf-primary"
    };

    private string GetDismissButtonClass() => Type switch
    {
        AlertType.Success => "float-right text-green-600 hover:text-green-800",
        AlertType.Error => "float-right text-red-600 hover:text-red-800",
        AlertType.Warning => "float-right text-yellow-600 hover:text-yellow-800",
        _ => "float-right text-bf-primary hover:text-bf-primary-contrast"
    };

    public enum AlertType
    {
        Success,
        Error,
        Warning,
        Info
    }
}
